<!-- PICA (Phenolic Impregnated Carbon Ablator) ablation in air -->
<!-- Species: phenolic decomposition products + air + solid graphite char -->
<!-- Pyrolysis gas composition from Goldstein (1992):                     -->
<!--   CH4:0.13, CO:0.23, CO2:0.11, H2:0.12, H2O:0.39, C2H4:0.02        -->
<!--   → elemental moles: C:0.51, H:1.62, O:0.84                         -->
<mixture thermo_db="NASA-9">

    <species>
       C H O N CH4 CN CO CO2 C2 C2H C2H2,acetylene C3 C4 C4H2,butadiyne C5 HCN
       H2 H2O N2 CH2OH CNN CNC CNCOCN C6H6 CH CH2 CH3 C2H4 C2H6 C3H3,1-propynl
       C3H3,2-propynl C6H5O,phenoxy C6H5OH,phenol O2 OH C(gr)
    </species>

    <element_compositions default="air">
        <composition name="air">N:0.79, O:0.21</composition>
        <composition name="pica_pyro">C:0.51, H:1.62, O:0.84</composition>
        <composition name="pica_char">C:1.0</composition>
    </element_compositions>

</mixture>
